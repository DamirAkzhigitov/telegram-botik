# Copy to .env and fill in. Never commit .env.

BOT_TOKEN=

# HTTPS URL of your dev tunnel (Cloudflare Tunnel / cloudflared → localhost:8787).
# After `pnpm serve`, copy the printed https://....trycloudflare.com (or your named tunnel URL).
# You can also set this in .dev.vars (same format) for Wrangler-centric workflows.
DEV_WEBHOOK_URL=

# Alias for DEV_WEBHOOK_URL (either works)
# CLOUDFLARE_TUNNEL_URL=
